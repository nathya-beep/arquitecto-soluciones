# ==========================================================================
# Arquitecto de Soluciones — variables de entorno (PLANTILLA)
# Copia este archivo a .env.local y rellena los valores. NUNCA subas .env.local.
# ==========================================================================

# --- IA (Groq) ------------------------------------------------------------
# API key de Groq (GRATIS): https://console.groq.com/keys  (empieza con "gsk_...")
GROQ_API_KEY=

# Modo de calidad de la IA:
#   balanced (por defecto) → entrevista con el 8b y Prompt Master con el 70b.
#   max                    → 70b en todo (requiere Groq Dev Tier de pago).
AI_QUALITY_MODE=balanced

# --- Envío de correos (Resend) --------------------------------------------
# API key de Resend: https://resend.com/api-keys  (empieza con "re_...")
RESEND_API_KEY=

# (Opcional) Remitente del correo a la dueña. Por defecto onboarding@resend.dev
# RESEND_FROM=Arquitecto de Soluciones <onboarding@resend.dev>

# (Opcional) Remitente del correo AL LEAD. Requiere DOMINIO VERIFICADO en Resend.
# RESEND_LEAD_FROM=Propuestas <propuestas@arquitecto.517luxury.com>

# --- Negocio --------------------------------------------------------------
# (Opcional) Correo que recibe los leads. Si se omite, usa el valor por defecto
# definido en el código. Configúralo aquí/en Vercel para no hardcodearlo.
# OWNER_EMAIL=tucorreo@ejemplo.com
